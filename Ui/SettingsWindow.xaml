<Window x:Class="Lumen.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        Title="{loc:Loc settings.title}" Height="500" Width="420" Topmost="True"
        Background="#1E1E1E" Foreground="#E6E6E6"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                            Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            Foreground="{TemplateBinding Foreground}"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            Focusable="False" Padding="4,3">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background" Value="#2D2D30"/>
                                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2"
                                                            SnapsToDevicePixels="True">
                                                        <Grid TextElement.Foreground="#F0F0F0">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"
                                                                                TextElement.Foreground="#F0F0F0"/>
                                                            <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#AAAAAA"
                                                                  HorizontalAlignment="Right" Margin="0,0,6,0"
                                                                  Width="8" Height="4" Stretch="Uniform"
                                                                  VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleY="-1" CenterX="4" CenterY="2"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{Binding IsChecked, ElementName=Toggle}"
                                   AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=Toggle}"
                                   StaysOpen="False" MaxHeight="300">
                                <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="2"
                                        SnapsToDevicePixels="True" Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Popup" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TxtTitle" Text="{loc:Loc settings.title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="{loc:Loc settings.language}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbLang" Width="180" DisplayMemberPath="Name" SelectedValuePath="Code"
                          SelectionChanged="CmbLang_SelectionChanged"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="ChkAutostart" Content="{loc:Loc settings.autostart}" Margin="0,2"/>
                <TextBlock x:Name="TxtAutostartHint" Text="{loc:Loc settings.autostart.hint}" FontSize="10" Foreground="#777" Margin="18,0,0,0"/>

                <TextBlock x:Name="TxtGrid" Text="{loc:Loc settings.gridSize}" Margin="0,14,0,4" Foreground="#9A9A9A"/>
                <ComboBox x:Name="CmbGrid" Width="160" HorizontalAlignment="Left">
                    <ComboBoxItem Content="20 px"/>
                    <ComboBoxItem Content="40 px"/>
                    <ComboBoxItem Content="60 px"/>
                    <ComboBoxItem Content="120 px"/>
                </ComboBox>

                <TextBlock x:Name="TxtPageBg" Text="{loc:Loc settings.pageBg}" Margin="0,14,0,4" Foreground="#9A9A9A"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton x:Name="RbSolid" Content="{loc:Loc settings.bg.solid}" GroupName="Bg" IsChecked="True" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RbImage" Content="{loc:Loc settings.bg.image}" GroupName="Bg"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtBgSolid" Width="120" Text="#FF1E1E1E" Background="#2D2D30" Foreground="#E6E6E6" BorderBrush="#3F3F46"/>
                    <Border x:Name="Swatch" Width="22" Height="20" Margin="6,0,0,0" BorderBrush="#555" BorderThickness="1"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBox x:Name="TxtBgImage" Width="220" IsEnabled="False" Background="#2D2D30" Foreground="#E6E6E6" BorderBrush="#3F3F46"/>
                    <Button x:Name="BtnBrowseBg" Content="{loc:Loc settings.browse}" Width="60" Margin="6,0,0,0" IsEnabled="False"/>
                </StackPanel>
                <Button x:Name="BtnApplyBg" Content="{loc:Loc settings.applyBg}" Width="100" Margin="0,6,0,0" HorizontalAlignment="Left"/>

                <TextBlock x:Name="TxtVisibility" Text="{loc:Loc settings.visibility}" Margin="0,14,0,4" Foreground="#9A9A9A"/>
                <Button x:Name="BtnToggle" Content="隐藏覆盖层" Width="120" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtHotkey" Text="{loc:Loc settings.hotkey}" Margin="0,4,0,0" Foreground="#9A9A9A" FontSize="11"/>

                <TextBlock x:Name="TxtProfileIo" Text="{loc:Loc settings.profileIo}" Margin="0,14,0,4" Foreground="#9A9A9A"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnExport" Content="{loc:Loc settings.export}" Width="100"/>
                    <Button x:Name="BtnImport" Content="{loc:Loc settings.import}" Width="100" Margin="6,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="TxtMulti" Text="{loc:Loc settings.multi}" Margin="0,14,0,4" Foreground="#9A9A9A"/>
                <TextBlock x:Name="TxtMultiTip" Text="{loc:Loc settings.multi.tip}" FontSize="11" Foreground="#777"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" x:Name="BtnClose" Content="{loc:Loc settings.close}" Width="80" HorizontalAlignment="Right" Margin="0,12,0,0"/>
    </Grid>
</Window>
