<Window x:Class="Lumen.Ui.AddComponentPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        Title="{loc:Loc addcomp.title}"
        Width="520" Height="420"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="CenterOwner">
    <Border Background="{StaticResource BgPanel}"
            BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusOuter}"
            Padding="16,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BgSurface}"
                    CornerRadius="6,6,0,0" Padding="10,6"
                    MouseLeftButtonDown="Header_MouseDown">
                <TextBlock Text="{loc:Loc addcomp.title}" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
            </Border>

            <!-- 卡片网格 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="0,8,0,8">
                <UniformGrid x:Name="CardGrid" Columns="3" Rows="4"/>
            </ScrollViewer>

            <!-- 底部关闭 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseBtn" Content="{loc:Loc settings.close}" Width="80"
                        Click="CloseBtn_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
