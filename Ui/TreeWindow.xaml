<Window x:Class="Lumen.Ui.TreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        Title="{loc:Loc tree.windowTitle}" Height="420" Width="260"
        Background="#1E1E1E" Foreground="#E6E6E6"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize" WindowStartupLocation="Manual">
    <Window.Resources>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D2D30"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3D41"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 标题栏（可拖拽） -->
            <Border Grid.Row="0" Background="#2D2D30" CornerRadius="6,6,0,0"
                    Padding="10,6" MouseLeftButtonDown="Header_MouseDown">
                <TextBlock Text="{loc:Loc tree.header}" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
            </Border>
            <!-- 树 -->
            <TreeView x:Name="AtomsTree" Grid.Row="1" Margin="4,2,4,2"
                      SelectedItemChanged="Tree_SelectedChanged"
                      AllowDrop="True"
                      PreviewMouseMove="Tree_PreviewMouseMove"
                      Drop="Tree_Drop"
                      DragOver="Tree_DragOver"/>
            <!-- 底部工具栏 -->
            <Border Grid.Row="2" Background="#252526" CornerRadius="0,0,6,6" Padding="6,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="AddBtn" Content="＋" Width="28" Margin="0,0,4,0" Click="Add_Click" ToolTip="{loc:Loc tree.add}"/>
                    <Button x:Name="UpBtn" Content="↑" Width="28" Margin="0,0,4,0" Click="Up_Click" ToolTip="{loc:Loc tree.up}"/>
                    <Button x:Name="DownBtn" Content="↓" Width="28" Margin="0,0,4,0" Click="Down_Click" ToolTip="{loc:Loc tree.down}"/>
                    <Button x:Name="DelBtn" Content="✕" Width="28" Click="Delete_Click" ToolTip="{loc:Loc tree.delete}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
