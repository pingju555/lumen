<Window x:Class="Lumen.Ui.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        Title="{loc:Loc profile.title}" Width="420" Height="470"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="8">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{loc:Loc profile.title}" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" x:Name="Hint" FontSize="11" Foreground="#9A9A9A" Margin="0,22,0,6"
                       Text="{loc:Loc profile.hint}"/>
            <ListBox x:Name="LstProfiles" Grid.Row="1" Background="#252526" Foreground="#F0F0F0"
                     BorderBrush="#3F3F46" SelectionChanged="LstProfiles_SelectionChanged"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,6">
                <Button x:Name="BtnNew" Content="{loc:Loc profile.new}" Width="64" Margin="0,0,6,0" Click="BtnNew_Click"/>
                <Button x:Name="BtnSwitch" Content="{loc:Loc profile.switch}" Width="64" Margin="0,0,6,0" Click="BtnSwitch_Click"/>
                <Button x:Name="BtnRename" Content="{loc:Loc profile.rename}" Width="64" Margin="0,0,6,0" Click="BtnRename_Click"/>
                <Button x:Name="BtnDelete" Content="{loc:Loc profile.delete}" Width="64" Margin="0,0,6,0" Click="BtnDelete_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button x:Name="BtnExport" Content="{loc:Loc settings.export}" Width="80" Margin="0,0,6,0" Click="BtnExport_Click"/>
                <Button x:Name="BtnImport" Content="{loc:Loc settings.import}" Width="80" Margin="0,0,6,0" Click="BtnImport_Click"/>
                <Button x:Name="BtnClose" Content="{loc:Loc settings.close}" Width="80" HorizontalAlignment="Right" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
