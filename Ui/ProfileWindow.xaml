<Window x:Class="Lumen.Ui.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置档（Profile）" Width="420" Height="470"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6" Margin="8">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="配置档（Profile）" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" x:Name="Hint" FontSize="11" Foreground="#9A9A9A" Margin="0,22,0,6"
                       Text="每档包含：全部页面（含部件）+ 每页设置 + 全局变量 + 用户预设。"/>
            <ListBox x:Name="LstProfiles" Grid.Row="1" Background="#252526" Foreground="#F0F0F0"
                     BorderBrush="#3F3F46" SelectionChanged="LstProfiles_SelectionChanged"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,6">
                <Button x:Name="BtnNew" Content="新建" Width="64" Margin="0,0,6,0" Click="BtnNew_Click"/>
                <Button x:Name="BtnSwitch" Content="切换" Width="64" Margin="0,0,6,0" Click="BtnSwitch_Click"/>
                <Button x:Name="BtnRename" Content="重命名" Width="64" Margin="0,0,6,0" Click="BtnRename_Click"/>
                <Button x:Name="BtnDelete" Content="删除" Width="64" Margin="0,0,6,0" Click="BtnDelete_Click"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button x:Name="BtnExport" Content="导出…" Width="80" Margin="0,0,6,0" Click="BtnExport_Click"/>
                <Button x:Name="BtnImport" Content="导入…" Width="80" Margin="0,0,6,0" Click="BtnImport_Click"/>
                <Button x:Name="BtnClose" Content="关闭" Width="80" HorizontalAlignment="Right" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
