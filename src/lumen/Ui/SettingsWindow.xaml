<ui:ChromeWindow x:Class="Lumen.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        xmlns:ui="clr-namespace:Lumen.Ui"
        x:Name="Win"
        TitleText="{loc:Loc settings.title}" Height="520" Width="460"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8,12,12">

            <!-- 界面语言 -->
            <TextBlock Text="{loc:Loc settings.language}" FontSize="11" Foreground="{StaticResource TextTertiary}" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbLang" Width="200" HorizontalAlignment="Left"
                      DisplayMemberPath="Name" SelectedValuePath="Code"
                      SelectionChanged="CmbLang_SelectionChanged"/>

            <Separator Margin="0,12,0,8"/>

            <!-- 开机自启 -->
            <CheckBox x:Name="ChkAutostart" Content="{loc:Loc settings.autostart}" Margin="0,2"/>
            <TextBlock x:Name="TxtAutostartHint" Text="{loc:Loc settings.autostart.hint}" FontSize="10"
                       Foreground="{StaticResource TextDisabled}" Margin="22,0,0,0" TextWrapping="Wrap"/>

            <Separator Margin="0,12,0,8"/>

            <!-- 封面缓存目录 -->
            <TextBlock x:Name="TxtCover" Text="{loc:Loc settings.cover}" FontSize="11"
                       Foreground="{StaticResource TextTertiary}" Margin="0,0,0,4"/>
            <ListBox x:Name="LstCoverDirs" Height="80" Margin="0,2"
                     Background="{StaticResource BgSunken}" Foreground="{StaticResource TextSecondary}"
                     BorderBrush="{StaticResource BorderDefault}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button x:Name="BtnAddCoverDir" Content="{loc:Loc settings.cover.add}" Width="96"
                        Background="{StaticResource BgHover}" Foreground="{StaticResource TextPrimary}" BorderThickness="0"/>
                <Button x:Name="BtnRemoveCoverDir" Content="{loc:Loc settings.cover.remove}" Width="96"
                        Margin="8,0,0,0"
                        Background="{StaticResource BgHover}" Foreground="{StaticResource TextPrimary}" BorderThickness="0"/>
            </StackPanel>
            <TextBlock x:Name="TxtCoverTip" Text="{loc:Loc settings.cover.tip}" FontSize="10"
                       Foreground="{StaticResource TextDisabled}" Margin="0,4,0,0" TextWrapping="Wrap"/>

            <Separator Margin="0,12,0,8"/>

            <!-- 覆盖层显隐 -->
            <TextBlock x:Name="TxtVisibility" Text="{loc:Loc settings.visibility}" FontSize="11"
                       Foreground="{StaticResource TextTertiary}" Margin="0,0,0,4"/>
            <Button x:Name="BtnToggle" Width="160" HorizontalAlignment="Left"
                    Background="{StaticResource BgHover}" Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                    Padding="8,4"/>
            <TextBlock x:Name="TxtHotkey" Text="{loc:Loc settings.hotkey}" Margin="0,4,0,0"
                       Foreground="{StaticResource TextDisabled}" FontSize="11"/>

            <Separator Margin="0,12,0,8"/>

            <!-- 多屏 -->
            <TextBlock x:Name="TxtMulti" Text="{loc:Loc settings.multi}" FontSize="11"
                       Foreground="{StaticResource TextTertiary}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtMultiTip" Text="{loc:Loc settings.multi.tip}" FontSize="11"
                       Foreground="{StaticResource TextDisabled}" TextWrapping="Wrap"/>

            <!-- 关闭 -->
            <Button x:Name="BtnClose" Content="{loc:Loc settings.close}" Width="100"
                    HorizontalAlignment="Right" Margin="0,16,0,0"
                    Background="{StaticResource BgHover}" Foreground="{StaticResource TextPrimary}" BorderThickness="0"/>

        </StackPanel>
    </ScrollViewer>
</ui:ChromeWindow>
