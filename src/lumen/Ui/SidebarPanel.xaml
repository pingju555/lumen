<UserControl x:Class="Lumen.Ui.SidebarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Lumen.I18n"
             x:Name="SidebarRoot"
             Width="300" Height="Auto"
             Background="Transparent"
             IsHitTestVisible="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 展开/收起按钮 -->
        <Border Grid.Column="0" x:Name="ToggleTab"
                Background="{StaticResource BgSurface}"
                CornerRadius="4,0,0,4"
                BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="1,1,0,1"
                Width="20" Height="80"
                VerticalAlignment="Center"
                Cursor="Hand"
                MouseLeftButtonDown="ToggleTab_MouseDown">
            <TextBlock x:Name="ToggleArrow" Text="◀"
                       FontSize="10" Foreground="{StaticResource TextTertiary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- 内容面板 -->
        <Border Grid.Column="1" x:Name="ContentPanel"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="0,1,0,1"
                CornerRadius="0"
                Width="280"
                HorizontalAlignment="Right"
                IsHitTestVisible="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 面包屑 -->
                    <RowDefinition Height="*"/>      <!-- TreeView -->
                    <RowDefinition Height="Auto"/>   <!-- 底部操作 -->
                </Grid.RowDefinitions>

                <!-- 面包屑导航 -->
                <Border Grid.Row="0" Background="{StaticResource BgSunken}" Padding="8,4"
                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1">
                    <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Border>

                <!-- TreeView -->
                <TreeView x:Name="AtomsTree" Grid.Row="1" Margin="2"
                          SelectedItemChanged="Tree_SelectedChanged"
                          MouseDoubleClick="Tree_MouseDoubleClick"
                          AllowDrop="True"
                          PreviewMouseMove="Tree_PreviewMouseMove"
                          Drop="Tree_Drop"
                          DragOver="Tree_DragOver"
                          Background="{StaticResource BgSunken}"
                          Foreground="{StaticResource TextSecondary}"
                          BorderThickness="0"/>

                <!-- 底部工具栏 -->
                <Border Grid.Row="2" Background="{StaticResource BgSunken}" Padding="6,4"
                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BackBtn" Content="←" Width="24" Height="22" Margin="0,0,6,0"
                                Click="Back_Click" ToolTip="{loc:Loc tree.back}" IsEnabled="False"
                                FontSize="11" Padding="2"/>
                        <Button x:Name="AddBtn" Content="＋" Width="24" Height="22" Margin="0,0,4,0"
                                Click="Add_Click" ToolTip="{loc:Loc tree.add}"
                                FontSize="11" Padding="2"/>
                        <Button x:Name="UpBtn" Content="↑" Width="24" Height="22" Margin="0,0,4,0"
                                Click="Up_Click" ToolTip="{loc:Loc tree.up}"
                                FontSize="11" Padding="2"/>
                        <Button x:Name="DownBtn" Content="↓" Width="24" Height="22" Margin="0,0,4,0"
                                Click="Down_Click" ToolTip="{loc:Loc tree.down}"
                                FontSize="11" Padding="2"/>
                        <Button x:Name="DelBtn" Content="✕" Width="24" Height="22"
                                Click="Delete_Click" ToolTip="{loc:Loc tree.delete}"
                                FontSize="11" Padding="2"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
