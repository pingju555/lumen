<Window x:Class="Lumen.Ui.PropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        x:Name="Win"
        Title="{loc:Loc propwin.title}"
        Height="640" Width="720"
        MinWidth="400" MinHeight="300"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="CanResize" WindowStartupLocation="Manual"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Border BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusOuter}"
            Background="{StaticResource BgPanel}" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BgSurface}"
                    CornerRadius="8,8,0,0" Padding="10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="12" Height="12"
                            CornerRadius="2" Background="{StaticResource BgActive}"
                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Grid.Column="1" x:Name="TitleText"
                               Text="{loc:Loc propwin.title}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="CloseBtn"
                            Content="✕" Width="22" Height="20"
                            FontSize="11" Padding="0"
                            Foreground="{StaticResource TextTertiary}"
                            Background="Transparent" BorderThickness="0"
                            ToolTip="关闭"/>
                </Grid>
            </Border>

            <!-- TabControl -->
            <TabControl Grid.Row="1" x:Name="MainTabs" Margin="0"
                        Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </TabControl.Resources>
            </TabControl>

            <!-- 底部操作栏：取消选中 + 应用/取消 -->
            <Border Grid.Row="2" Background="{StaticResource BgSurface}"
                    Padding="8,6" BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="DeselectBtn"
                            Content="取消选中" Width="80" Height="24"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondary}"
                            Background="{StaticResource BgHover}"
                            BorderThickness="0" Padding="4,0"/>
                    <Button Grid.Column="2" x:Name="CancelBtn"
                            Content="取消" Width="60" Height="24"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondary}"
                            Background="{StaticResource BgHover}"
                            BorderThickness="0" Padding="4,0"/>
                    <Button Grid.Column="3" x:Name="ApplyBtn"
                            Content="应用" Width="60" Height="24"
                            FontSize="11"
                            Foreground="{StaticResource TextPrimary}"
                            Background="{StaticResource BgActive}"
                            BorderThickness="0" Padding="4,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
