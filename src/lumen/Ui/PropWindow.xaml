<ui:ChromeWindow x:Class="Lumen.Ui.PropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Lumen.I18n"
        xmlns:ui="clr-namespace:Lumen.Ui"
        x:Name="Win"
        TitleText="{loc:Loc propwin.title}" Height="640" Width="720"
        MinWidth="400" MinHeight="300"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize" WindowStartupLocation="Manual">
    <ui:ChromeWindow.FooterContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="DeselectBtn"
                    Content="{loc:Loc propwin.clear}" Width="84" Height="24"
                    FontSize="11"/>
            <Button Grid.Column="2" x:Name="CancelBtn"
                    Content="{loc:Loc propwin.cancel}" Width="64" Height="24"
                    Margin="0,0,6,0" FontSize="11"/>
            <Button Grid.Column="3" x:Name="ApplyBtn"
                    Content="{loc:Loc propwin.apply}" Width="64" Height="24"
                    FontSize="11" Background="{StaticResource BgActive}" Foreground="{StaticResource TextPrimary}"/>
        </Grid>
    </ui:ChromeWindow.FooterContent>

    <!-- 主内容：动态 TabControl（由代码填充） -->
    <TabControl x:Name="MainTabs" Margin="0"
                Background="Transparent" BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabPanel">
                <Setter Property="Background" Value="{StaticResource BgSurface}"/>
                <Setter Property="Margin" Value="0"/>
            </Style>
        </TabControl.Resources>
    </TabControl>
</ui:ChromeWindow>
